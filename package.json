{
  "name": "epub-css-validator",
  "version": "1.0.0",
  "description": "Command-line tool to validate CSS in EPUB files using Calibre's stylelint rules",
  "main": "lib/validator.js",
  "bin": {
    "epub-css-validator": "./bin/epub-css-validator.js"
  },
  "scripts": {
    "test": "node bin/epub-css-validator.js --help",
    "update-config": "node bin/epub-css-validator.js --update-config"
  },
  "keywords": [
    "epub",
    "css",
    "validator",
    "stylelint",
    "calibre",
    "lint"
  ],
  "author": "",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "glob": "^10.3.0",
    "jszip": "^3.10.0",
    "stylelint": "^15.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
