{
  "name": "epub-css-validator",
  "version": "0.1.0",
  "description": "Command-line tool to validate CSS in EPUB files using Calibre's stylelint rules",
  "type": "module",
  "main": "dist/lib/core.js",
  "bin": {
    "epub-css-validator": "./dist/bin/epub-css-validator.js"
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "vitest --no-coverage",
    "test:run": "vitest run --no-coverage",
    "test:coverage": "vitest run --coverage",
    "test:package": "vitest run tests/integration/package.test.js",
    "update-config": "tsx bin/epub-css-validator.ts --update-config",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "epub",
    "css",
    "validator",
    "stylelint",
    "calibre",
    "lint"
  ],
  "author": "Jeff Spiers",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jspiers/epub-css-validator.git"
  },
  "homepage": "https://github.com/jspiers/epub-css-validator#readme",
  "bugs": {
    "url": "https://github.com/jspiers/epub-css-validator/issues"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "glob": "^10.4.0",
    "jszip": "^3.10.0",
    "stylelint": "^16.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "vitest": {
    "testTimeout": 10000,
    "coverage": {
      "provider": "v8",
      "reportsDirectory": "tests/coverage",
      "reporter": [
        "text",
        "json",
        "html"
      ],
      "exclude": [
        "node_modules/",
        "tests/",
        "*.test.js",
        "*.config.js"
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
