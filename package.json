{
  "name": "epub-css-validator",
  "version": "1.0.0",
  "description": "Command-line tool to validate CSS in EPUB files using Calibre's stylelint rules",
  "type": "module",
  "main": "lib/validator.js",
  "bin": {
    "epub-css-validator": "./bin/epub-css-validator.js"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "update-config": "node bin/epub-css-validator.js --update-config"
  },
  "keywords": [
    "epub",
    "css",
    "validator",
    "stylelint",
    "calibre",
    "lint"
  ],
  "author": "",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "glob": "^10.4.0",
    "jszip": "^3.10.0",
    "stylelint": "^16.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "vitest": {
    "testTimeout": 10000,
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "json", "html"],
      "exclude": [
        "node_modules/",
        "tests/",
        "*.test.js",
        "*.config.js"
      ]
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
